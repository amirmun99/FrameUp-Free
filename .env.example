# Notion OAuth — optional, only needed for Notion page capture
# Client ID can be VITE_ (safe to expose). Secret must NOT use VITE_ prefix.
VITE_NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Google OAuth — optional, only needed for Google Sheets capture
# Client ID can be VITE_ (safe to expose). Secret must NOT use VITE_ prefix.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
